<%- include('partials/header', { pageTitle: 'new exercise', pageClass: 'page-workouts' }) %>
<%- include('partials/nav') %>

<h1>Add Exercise To Workout</h1>
<h1><%= workout.workout_name %></h1>
    
<div class="table-shell">
    <table class="table align-middle">
        <thead>
            <tr>
                <th scope="col">Date</th>
                <th scope="col">Duration</th>
                <th scope="col">Notes</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><%= workout.workout_date %></td>
                <td><%= workout.duration_minutes %> min</td>
                <td><%= workout.notes || 'No notes added.' %></td>
            </tr>
        </tbody>
    </table>
</div>
<% if (message) { %>
    <p class="success-message"><%= message %></p>
<% } %>
<section class="content-grid mt-4">
    <section class="content-panel">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
            <div>
                <h2 class="panel-title">Excerises</h2>
                <p class="panel-copy">Add an exercise</p>
            </div>
        </div>

            <form action="/workouts/<%= workout.workout_id %>/exercises/new" method="POST" class="exercise-form">
                <div>
                    <label for="exercise_name">Exercise Name:</label>
                    <input type="text" id="exercise_name" name="exercise_name" required>
                </div>

                <div>
                    <label for="exercise_type">Exercise Type:</label>
                    <select id="exercise_type" name="exercise_type">
                        <option value="">Select Type</option>
                        <option value="Strength">Strength</option>
                        <option value="Cardio">Cardio</option>
                        <option value="Flexibility">Flexibility</option>
                        <option value="Sports">Sports</option>
                    </select>
                </div>

                <div>
                    <label for="sets">Sets:</label>
                    <input type="number" id="sets" name="sets" min="0">
                </div>

                <div>
                    <label for="reps">Reps:</label>
                    <input type="number" id="reps" name="reps" min="0">
                </div>

                <div>
                    <label for="weight">Weight:</label>
                    <input type="number" id="weight" name="weight" min="0" step="0.01">
                </div>

                <div>
                    <label for="distance">Distance:</label>
                    <input type="number" id="distance" name="distance" min="0" step="0.01">
                </div>

                <div class="button-group">
                    <button type="submit">Add Exercise</button>
                    <a href="/workouts/<%= workout.workout_id %>/exercises">View Exercises</a>
                    <a href="/workouts/history">Back to Workout History</a>
                </div>
            </form>
    </section>
</section>

<%- include('partials/footer.ejs') %>